      "height": 50,
      "bg_color": "#F3F0FF",
      "header_color": "#228BE6"
    },
    "results": {
      "height": 120,
      "bg_color": "#FFF9DB",
      "header_color": "#FF6B9D"
    }
  },

  "buttons": {
    "control_panel": [
      {"text": "Load File", "color": "btn_load"},
      {"text": "◀", "color": "btn_nav", "width": 35},
      {"text": "▶", "color": "btn_nav", "width": 35},
      {"text": "Fit Peaks", "color": "btn_fit"},
      {"text": "Reset", "color": "btn_reset"},
      {"text": "Save Results", "color": "btn_save"},
      {"text": "Clear Fit", "color": "btn_clear"},
      {"text": "Undo", "color": "btn_undo"},
      {"text": "Auto Find", "color": "btn_auto"},
      {"text": "Overlap", "color": "btn_overlap"},
      {"text": "Batch Auto Fit", "color": "btn_batch"},
      {"text": "⚙", "color": "btn_settings", "width": 35}
    ],
    "background": [
